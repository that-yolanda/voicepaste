{
  "name": "voicepaste",
  "version": "2.0.0",
  "description": "Voice-to-text input tool — press a hotkey, speak, auto-paste.",
  "author": "that-yolanda",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/that-yolanda/voicepaste.git"
  },
  "homepage": "https://github.com/that-yolanda/voicepaste#readme",
  "bugs": {
    "url": "https://github.com/that-yolanda/voicepaste/issues"
  },
  "keywords": [
    "tauri",
    "voice",
    "speech-to-text",
    "asr",
    "macos",
    "windows",
    "doubao",
    "volcengine"
  ],
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "pack": "node --env-file=.env scripts/pack.js",
    "clean": "node scripts/clean.js",
    "lint": "biome lint ./web",
    "format": "biome format --write ./web",
    "check": "biome check --write ./web",
    "lint:ci": "biome ci ./web",
    "test": "npx vitest run && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:asr": "cargo test --manifest-path src-tauri/Cargo.toml --features asr-integration",
    "test:llm": "cargo test --manifest-path src-tauri/Cargo.toml --features llm-integration",
    "test:frontend": "npx vitest run",
    "test:watch": "npx vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tauri-apps/cli": "^2",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "lucide": "^1.14.0",
    "vitest": "^4.1.8"
  }
}
