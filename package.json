{
  "name": "voicepaste",
  "version": "1.0.3",
  "description": "Voice-to-text input tool — press a hotkey, speak, auto-paste.",
  "author": "that-yolanda",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/that-yolanda/voicepaste.git"
  },
  "homepage": "https://github.com/that-yolanda/voicepaste#readme",
  "bugs": {
    "url": "https://github.com/that-yolanda/voicepaste/issues"
  },
  "keywords": [
    "electron",
    "voice",
    "speech-to-text",
    "asr",
    "macos",
    "windows",
    "doubao",
    "volcengine"
  ],
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --mac zip",
    "pack:win": "electron-builder --win nsis --x64",
    "postinstall": "node node_modules/.pnpm/electron@41.2.0/node_modules/electron/install.js"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "uiohook-napi": "^1.5.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "build": {
    "appId": "com.yolanda.voicepaste",
    "productName": "VoicePaste",
    "npmRebuild": false,
    "files": [
      "main/**/*",
      "preload/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "config.yaml.example",
        "to": "config.yaml"
      },
      {
        "from": "config.yaml.example",
        "to": "config.yaml.example"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/trayTemplate.png",
        "to": "trayTemplate.png"
      },
      {
        "from": "build/trayTemplate@2x.png",
        "to": "trayTemplate@2x.png"
      },
      {
        "from": "build/trayIcon.ico",
        "to": "trayIcon.ico"
      }
    ],
    "mac": {
      "icon": "build/icon.png",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "用于录制你的语音并将识别结果粘贴到当前输入位置。"
      },
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VoicePaste",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true
    }
  }
}
