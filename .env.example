# Apple Developer credentials for signing and notarization (macOS only)
APPLE_ID=your-apple-id@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAMID)

# Tauri updater signing key (required for release builds with updater artifacts)
# Generate with: pnpm tauri signer generate -w ../doc/tauri/voicepaste.key
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
