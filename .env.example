# Apple Developer credentials for signing and notarization (macOS only)
# APPLE_* is used for notarization.
# CSC_NAME is optional and pins a specific certificate from Keychain.
# If CSC_NAME is omitted, electron-builder will auto-discover a valid signing identity.
# Set CSC_IDENTITY_AUTO_DISCOVERY=false only if you want the build to fail instead of auto-picking another cert.
APPLE_ID=your-apple-id@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX
CSC_NAME="Developer ID Application: Your Name (TEAMID)"
# CSC_IDENTITY_AUTO_DISCOVERY=false
