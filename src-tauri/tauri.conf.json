{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "VoicePaste",
  "identifier": "com.yolanda.voicepaste",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx tsx scripts/validate-json.ts && vite",
    "beforeBuildCommand": "npx tsx scripts/validate-json.ts && vite build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "url": "settings.html",
        "title": "VoicePaste 配置",
        "width": 860,
        "height": 760,
        "minWidth": 760,
        "minHeight": 680,
        "visible": true,
        "decorations": true,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../config.yaml.example": "config.yaml.example",
      "../prompts.json": "prompts.json",
      "../hotwords.json": "hotwords.json",
      "../registry.json": "registry.json",
      "../assets/sounds/start.mp3": "sounds/start.mp3",
      "../assets/sounds/end.mp3": "sounds/end.mp3",
      "icons/icon.png": "icons/icon.png",
      "icons/trayTemplate.png": "icons/trayTemplate.png"
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4RUIyQzJCRTMxMDIxMkYKUldRdklSRGpLeXpyT1BZTzBRdndtZURTZVY4b01sSHRabk9zVHN5WXNWQm5sTnpTR21ZQUVJZEgK",
      "endpoints": [
        "https://github.com/that-yolanda/voicepaste/releases/latest/download/latest.json"
      ]
    }
  }
}
