# VoicePaste 配置文件
#
# 所有参数的默认值见 registry.json。
# 本文件仅记录你修改过的参数，未列出的参数自动从 registry.json 读取默认值。
# 通过设置 UI 修改任意参数后，对应字段会自动写入此文件。

app:
  hotkey: F13
  hotkey_mode: toggle             # toggle=按一次开始再按一次结束，hold=按住说话松开结束
  remove_trailing_period: true    # 自动删除识别结果末尾的句号
  keep_clipboard: true            # 保留识别结果在剪贴板
  theme: system                   # dark / light / system
  overlay_style: liquid           # macOS 悬浮窗外观（仅 macOS 生效）
  sound:
    enabled: true
    start_sound: ""
    end_sound: ""
  beta_updates: false

audio:
  provider: doubao-streaming      # 默认 ASR 引擎，切换模型后自动更新
  # 如需使用豆包流式 ASR，在设置 UI 中填写凭据。
  # 如需使用本地 sherpa-onnx 模型，在设置 UI 中切换并下载模型。
  # 修改任何参数后，对应模型配置段会自动追加到此文件。

llm:
  provider: deepseek
  deepseek:
    api_key: ""
    model: deepseek-v4-flash
