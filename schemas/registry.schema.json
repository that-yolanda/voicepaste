{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voicepaste.local/schemas/registry.schema.json",
  "type": "object",
  "required": ["version", "updated_at", "models"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer" },
    "updated_at": { "type": "string" },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "asr": {
          "type": "object",
          "description": "Shared ASR defaults applied before model-specific defaults.",
          "additionalProperties": true
        },
        "vad": {
          "type": "object",
          "description": "Shared VAD defaults applied before silero-vad defaults.",
          "additionalProperties": true
        }
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "category", "engine", "name", "description", "tags"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["online", "offline"] },
          "category": { "type": "string", "enum": ["asr", "vad", "punctuation"] },
          "engine": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "languages": {
            "type": "array",
            "items": { "type": "string" }
          },
          "capabilities": {
            "type": "object",
            "required": ["streaming", "hotwords", "punctuation", "itn"],
            "additionalProperties": false,
            "properties": {
              "streaming": { "type": "boolean" },
              "hotwords": { "type": "boolean" },
              "punctuation": { "type": "boolean" },
              "itn": { "type": "boolean" }
            }
          },
          "requires_config": {
            "type": "array",
            "description": "Online models only: config keys the user must fill.",
            "items": { "type": "string" }
          },
          "architecture": { "type": "string" },
          "download_url": { "type": "string" },
          "file_size": { "type": "integer" },
          "mem_size": { "type": "integer" },
          "model_files": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "default_config": {
            "type": "object",
            "description": "Model-specific default config. Merged on top of defaults.asr.",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
