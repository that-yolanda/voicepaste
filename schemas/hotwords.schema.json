{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voicepaste.local/schemas/hotwords.schema.json",
  "type": "object",
  "required": ["active_group", "groups"],
  "additionalProperties": false,
  "properties": {
    "active_group": { "type": "string" },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "words"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "words": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
